#!/bin/bash
# sync-tix-to-vault — Crawl local .tix dirs and write a summary to the vault
# Runs periodically via launchd; Syncthing carries it to the VPS for Sedge

set -euo pipefail

VAULT="$HOME/notes"
OUT="$VAULT/Projects/.tix-overview.md"
SEARCH_DIR="$HOME/src/hack"
TIX="/opt/homebrew/bin/tix"

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

cat > "$tmp" <<EOF
---
updated: $now
type: auto-generated
---
# Open Tasks Across Projects

> Auto-generated by sync-tix-to-vault. Do not edit manually.
> Last updated: $now

EOF

total_open=0
total_projects=0

for dir in "$SEARCH_DIR"/*/; do
  [ -f "$dir/.tix/issues.jsonl" ] || continue
  name=$(basename "$dir")

  # Get open + in_progress issues (tix requires cwd to be the project dir)
  open_json=$(cd "$dir" && "$TIX" list --status open --json 2>/dev/null || echo "[]")
  progress_json=$(cd "$dir" && "$TIX" list --status in_progress --json 2>/dev/null || echo "[]")

  # Merge and count
  count=$(echo "$open_json $progress_json" | python3 -c "
import json, sys
parts = sys.stdin.read().split('] [')
items = []
for p in parts:
    p = p.strip()
    if not p.startswith('['): p = '[' + p
    if not p.endswith(']'): p = p + ']'
    try: items.extend(json.loads(p))
    except: pass
print(len(items))
")

  [ "$count" -eq 0 ] && continue

  total_projects=$((total_projects + 1))
  total_open=$((total_open + count))

  echo "## $name" >> "$tmp"
  echo "" >> "$tmp"

  # Print in_progress first, then open, sorted by priority
  echo "$open_json $progress_json" | python3 -c "
import json, sys
parts = sys.stdin.read().split('] [')
items = []
for p in parts:
    p = p.strip()
    if not p.startswith('['): p = '[' + p
    if not p.endswith(']'): p = p + ']'
    try: items.extend(json.loads(p))
    except: pass
# Sort: in_progress first, then by priority (1=highest)
items.sort(key=lambda x: (0 if x.get('status')=='in_progress' else 1, x.get('priority', 5)))
for item in items:
    status = 'WIP' if item.get('status') == 'in_progress' else 'open'
    pri = item.get('priority', '?')
    assignee = item.get('assignee', '')
    assign_str = f' @{assignee}' if assignee else ''
    print(f\"- [{status}] **P{pri}** {item['title']}{assign_str} (\`{item['id']}\`)\")
" >> "$tmp"

  echo "" >> "$tmp"
done

# Add summary at top (after frontmatter)
sed -i '' "s|Last updated: $now|Last updated: $now\n> $total_open open tasks across $total_projects projects|" "$tmp"

mv "$tmp" "$OUT"
