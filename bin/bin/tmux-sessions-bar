#!/usr/bin/env bash
# tmux-sessions-bar — render session list with per-session colors and alert badges

BG="#1a1c22"
BG_DIM="#282b31"
AMBER="#f2a633"

current=$(tmux display-message -p '#S')

out=""
i=1
while IFS=$'\t' read -r name alerts; do
  color=$(~/bin/tmux-session-color "$i")
  badge=""
  if [[ "$alerts" == *"!"* ]]; then
    badge="#[fg=#bbff00]●"
  fi

  if [[ "$name" == "$current" ]]; then
    out+="#[bg=$color,fg=$BG,bold] $name ${badge} #[default]"
  else
    out+="#[bg=$BG_DIM,fg=$color] $name ${badge} #[default]"
  fi
  i=$((i + 1))
done < <(tmux list-sessions -F '#{session_name}	#{session_alerts}' 2>/dev/null)

echo "$out"
