# use # to comment

# Mode definitions with JankyBorders color feedback + Sketchybar
# Human++ palette: pink=#e7349c green=#04b372 cyan=#1ad0d6 amber=#f2a633 purple=#9871fe orange=#f26c33
:: default : borders active_color=0xffe7349c; sketchybar --trigger mode_change MODE=default
:: switcher @ : borders active_color=0xff1ad0d6; sketchybar --trigger mode_change MODE=switcher
:: swap @ : borders active_color=0xff458ae2; sketchybar --trigger mode_change MODE=swap
:: tree @ : borders active_color=0xfff2a633; sketchybar --trigger mode_change MODE=tree
:: layout @ : borders active_color=0xff9871fe; sketchybar --trigger mode_change MODE=layout
:: meet @ : borders active_color=0xfff26c33; sketchybar --trigger mode_change MODE=meet
:: tmux @ : borders active_color=0xffbbff00; sketchybar --trigger mode_change MODE=tmux


# =====================================================
# QUICK ACTIONS (no mode required)
# =====================================================
alt - e : skl default alt+e balance; yabai -m space --balance
alt - r : skl default alt+r rotate; yabai -m space --rotate 90
alt - f : skl default alt+f fullscreen; yabai -m window --toggle zoom-fullscreen
alt - t : skl default alt+t float; yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2

# =====================================================
# SPACE FOCUS (cycle stack if already on that space)
# =====================================================
ctrl - 1 : skl default ctrl+1 space:1; [ "$(yabai -m query --spaces --space | jq '.index')" = "1" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 1
ctrl - 2 : skl default ctrl+2 space:2; [ "$(yabai -m query --spaces --space | jq '.index')" = "2" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 2
ctrl - 3 : skl default ctrl+3 space:3; [ "$(yabai -m query --spaces --space | jq '.index')" = "3" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 3
ctrl - 4 : skl default ctrl+4 space:4; [ "$(yabai -m query --spaces --space | jq '.index')" = "4" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 4
ctrl - 5 : skl default ctrl+5 space:5; [ "$(yabai -m query --spaces --space | jq '.index')" = "5" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 5
ctrl - 6 : skl default ctrl+6 space:6; [ "$(yabai -m query --spaces --space | jq '.index')" = "6" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 6
ctrl - 7 : skl default ctrl+7 space:7; [ "$(yabai -m query --spaces --space | jq '.index')" = "7" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 7
ctrl - 8 : skl default ctrl+8 space:8; [ "$(yabai -m query --spaces --space | jq '.index')" = "8" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 8
ctrl - 9 : skl default ctrl+9 space:9; [ "$(yabai -m query --spaces --space | jq '.index')" = "9" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 9
ctrl - 0 : skl default ctrl+0 space:10; [ "$(yabai -m query --spaces --space | jq '.index')" = "10" ] && { yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first 2>/dev/null; } || yabai -m space --focus 10

# =====================================================
# NAVIGATION
# =====================================================
# streamline window/pane movement keybinds for vim splits and windows
# pass through to app if it's a terminal (vim/tmux handle hjkl internally)
ctrl - h -> : app=$(yabai -m query --windows --window | jq -r '.app'); if [[ "$app" != "Ghostty" && "$app" != "Terminal" && "$app" != "iTerm2" && "$app" != "kitty" && "$app" != "Alacritty" && "$app" != "WezTerm" ]]; then skl default ctrl+h focus:west; yabai -m window --focus west; fi
ctrl - j -> : app=$(yabai -m query --windows --window | jq -r '.app'); if [[ "$app" != "Ghostty" && "$app" != "Terminal" && "$app" != "iTerm2" && "$app" != "kitty" && "$app" != "Alacritty" && "$app" != "WezTerm" ]]; then skl default ctrl+j focus:south; yabai -m window --focus south; fi
ctrl - k -> : app=$(yabai -m query --windows --window | jq -r '.app'); if [[ "$app" != "Ghostty" && "$app" != "Terminal" && "$app" != "iTerm2" && "$app" != "kitty" && "$app" != "Alacritty" && "$app" != "WezTerm" ]]; then skl default ctrl+k focus:north; yabai -m window --focus north; fi
ctrl - l -> : app=$(yabai -m query --windows --window | jq -r '.app'); if [[ "$app" != "Ghostty" && "$app" != "Terminal" && "$app" != "iTerm2" && "$app" != "kitty" && "$app" != "Alacritty" && "$app" != "WezTerm" ]]; then skl default ctrl+l focus:east; yabai -m window --focus east; fi

# switching modes
default                        < ctrl - f      ; switcher
switcher, swap, layout, tree, tmux < ctrl - f      ; default
switcher, swap, layout, tree, tmux < escape        ; default

# meet mode - ctrl+m to enter/exit
default                              < ctrl - m      ; meet
meet                                 < ctrl - m      ; default
meet                                 < escape        ; default


# switcher mode

## switch modes (mnemonic keys)
switcher < m ; swap      # m = Move
switcher < l ; layout    # l = Layout
switcher < s ; tree      # s = Size
switcher < g ; meet      # g = Google Meet
switcher < t ; tmux      # t = Tmux

## organize windows (LLM-powered)
switcher < o : skl switcher o organize; ~/bin/yabai-organize &; \
    sketchybar --trigger keybind_flash ACTION="organize"; skhd -k 'escape'

## launch terminal
switcher < return : skl switcher return term; ~/bin/ghostty-create-window; skhd -k 'escape'

## move window to desktop and follow
switcher < cmd + shift - 1 : skl switcher cmd+shift+1 move+follow:1; yabai -m window --space 1; yabai -m space --focus 1
switcher < cmd + shift - 2 : skl switcher cmd+shift+2 move+follow:2; yabai -m window --space 2; yabai -m space --focus 2
switcher < cmd + shift - 3 : skl switcher cmd+shift+3 move+follow:3; yabai -m window --space 3; yabai -m space --focus 3
switcher < cmd + shift - 4 : skl switcher cmd+shift+4 move+follow:4; yabai -m window --space 4; yabai -m space --focus 4
switcher < cmd + shift - 5 : skl switcher cmd+shift+5 move+follow:5; yabai -m window --space 5; yabai -m space --focus 5
switcher < cmd + shift - 6 : skl switcher cmd+shift+6 move+follow:6; yabai -m window --space 6; yabai -m space --focus 6
switcher < cmd + shift - 7 : skl switcher cmd+shift+7 move+follow:7; yabai -m window --space 7; yabai -m space --focus 7
switcher < cmd + shift - 8 : skl switcher cmd+shift+8 move+follow:8; yabai -m window --space 8; yabai -m space --focus 8
switcher < cmd + shift - 9 : skl switcher cmd+shift+9 move+follow:9; yabai -m window --space 9; yabai -m space --focus 9
switcher < cmd + shift - 0 : skl switcher cmd+shift+0 move+follow:10; yabai -m window --space 10; yabai -m space --focus 10

## move window to desktop (no follow)
switcher < shift - 1 : skl switcher shift+1 send:1; yabai -m window --space 1; sketchybar --trigger keybind_flash ACTION="→ 1"
switcher < shift - 2 : skl switcher shift+2 send:2; yabai -m window --space 2; sketchybar --trigger keybind_flash ACTION="→ 2"
switcher < shift - 3 : skl switcher shift+3 send:3; yabai -m window --space 3; sketchybar --trigger keybind_flash ACTION="→ 3"
switcher < shift - 4 : skl switcher shift+4 send:4; yabai -m window --space 4; sketchybar --trigger keybind_flash ACTION="→ 4"
switcher < shift - 5 : skl switcher shift+5 send:5; yabai -m window --space 5; sketchybar --trigger keybind_flash ACTION="→ 5"
switcher < shift - 6 : skl switcher shift+6 send:6; yabai -m window --space 6; sketchybar --trigger keybind_flash ACTION="→ 6"
switcher < shift - 7 : skl switcher shift+7 send:7; yabai -m window --space 7; sketchybar --trigger keybind_flash ACTION="→ 7"
switcher < shift - 8 : skl switcher shift+8 send:8; yabai -m window --space 8; sketchybar --trigger keybind_flash ACTION="→ 8"
switcher < shift - 9 : skl switcher shift+9 send:9; yabai -m window --space 9; sketchybar --trigger keybind_flash ACTION="→ 9"
switcher < shift - 0 : skl switcher shift+0 send:10; yabai -m window --space 10; sketchybar --trigger keybind_flash ACTION="→ 10"

## focus monitor
switcher < x : skl switcher x mon:last; yabai -m display --focus last; sketchybar --trigger keybind_flash ACTION="mon last"
switcher < z : skl switcher z mon:prev; yabai -m display --focus prev; sketchybar --trigger keybind_flash ACTION="mon prev"
switcher < c : skl switcher c mon:next; yabai -m display --focus next; sketchybar --trigger keybind_flash ACTION="mon next"
switcher < 1 : skl switcher 1 mon:1; yabai -m display --focus 1
switcher < 2 : skl switcher 2 mon:2; yabai -m display --focus 2

## send to monitor and follow focus
switcher < cmd - x : skl switcher cmd+x send-mon:last; yabai -m window --display last; yabai -m display --focus last
switcher < cmd - z : skl switcher cmd+z send-mon:prev; yabai -m window --display prev; yabai -m display --focus prev
switcher < cmd - c : skl switcher cmd+c send-mon:next; yabai -m window --display next; yabai -m display --focus next
switcher < cmd - 1 : skl switcher cmd+1 send-mon:1; yabai -m window --display 1; yabai -m display --focus 1
switcher < cmd - 2 : skl switcher cmd+2 send-mon:2; yabai -m window --display 2; yabai -m display --focus 2

# tmux mode — control tmux from skhd
# note: skhd runs outside tmux, so use display-popup for interactive commands
# and avoid #{format} strings (they don't expand from outside tmux)

## session management
tmux < f : skl tmux f session:pick; tmux display-popup -w 90% -h 80% -E "~/bin/tmux-sessionizer"; skhd -k 'escape'
tmux < space : skl tmux space session:last; tmux switch-client -l
tmux < r : skl tmux r session:rename; skhd -k 'escape'; tmux command-prompt -I "#S" "rename-session -- '%%'"
tmux < x : skl tmux x session:kill; tmux display-popup -E "tmux confirm-before -p 'kill session? (y/n)' kill-session"

## window (tab) navigation — stays in tmux mode so you can browse
tmux < 1 : skl tmux 1 win:1; tmux select-window -t :1
tmux < 2 : skl tmux 2 win:2; tmux select-window -t :2
tmux < 3 : skl tmux 3 win:3; tmux select-window -t :3
tmux < 4 : skl tmux 4 win:4; tmux select-window -t :4
tmux < 5 : skl tmux 5 win:5; tmux select-window -t :5
tmux < 6 : skl tmux 6 win:6; tmux select-window -t :6
tmux < 7 : skl tmux 7 win:7; tmux select-window -t :7
tmux < 8 : skl tmux 8 win:8; tmux select-window -t :8
tmux < 9 : skl tmux 9 win:9; tmux select-window -t :9
tmux < h : skl tmux h win:prev; tmux previous-window
tmux < l : skl tmux l win:next; tmux next-window
tmux < n : skl tmux n session:next; tmux switch-client -n
tmux < p : skl tmux p session:prev; tmux switch-client -p

## window actions — exit tmux mode after
tmux < c : skl tmux c win:new; tmux new-window; skhd -k 'escape'
tmux < d : skl tmux d win:kill; [ "$(tmux list-windows | wc -l | tr -d ' ')" -gt 1 ] && tmux kill-window || tmux display-message "last window — use x to kill session"
tmux < w : skl tmux w win:rename; skhd -k 'escape'; tmux command-prompt -I "#W" "rename-window -- '%%'"

## pane splitting
tmux < return : skl tmux return split:h; tmux split-window -v; skhd -k 'escape'
tmux < 0x2A : skl tmux \\ split:v; tmux split-window -h; skhd -k 'escape'

# swap mode
## swap window positions
swap < h : skl swap h swap:west; yabai -m window --swap west
swap < j : skl swap j swap:south; yabai -m window --swap south
swap < k : skl swap k swap:north; yabai -m window --swap north
swap < l : skl swap l swap:east; yabai -m window --swap east

## warp window
swap < shift - h : skl swap shift+h warp:west; yabai -m window --warp west
swap < shift - j : skl swap shift+j warp:south; yabai -m window --warp south
swap < shift - k : skl swap shift+k warp:north; yabai -m window --warp north
swap < shift - l : skl swap shift+l warp:east; yabai -m window --warp east

## mirror tree y-axis
swap < y : skl swap y mirror:y; yabai -m space --mirror y-axis

## mirror tree x-axis
swap < x : skl swap x mirror:x; yabai -m space --mirror x-axis

## stack operations
swap < s : skl swap s stack:next; yabai -m window --stack next

# layout mode
## change desktop layout
layout < a : skl layout a layout:bsp; yabai -m space --layout bsp
layout < s : skl layout s layout:stack; yabai -m space --layout stack
layout < d : skl layout d layout:float; yabai -m space --layout float

## toggle desktop offset
layout < o : skl layout o toggle:padding; yabai -m space --toggle padding; yabai -m space --toggle gap

# tree mode
tree < f                :   skl tree f zoom:full; yabai -m window --toggle zoom-fullscreen
tree < shift - f        :   skl tree shift+f zoom:native; yabai -m window --toggle native-fullscreen
tree < d                :   skl tree d zoom:parent; yabai -m window --toggle zoom-parent
tree < w                :   skl tree w float:center; yabai -m window --toggle float;\
                            yabai -m window --grid 4:4:1:1:2:2
tree < r                :   skl tree r rotate; yabai -m space --rotate 90
tree < s                :   skl tree s split; yabai -m window --toggle split
tree < m                :   skl tree m minimize; yabai -m window --minimize

## adjust window size
tree < h                :   skl tree h resize:left; yabai -m window --resize left:-20:0
tree < j                :   skl tree j resize:down; yabai -m window --resize bottom:0:20
tree < k                :   skl tree k resize:up; yabai -m window --resize top:0:-20
tree < l                :   skl tree l resize:right; yabai -m window --resize right:20:0

tree < shift - h        :   skl tree shift+h shrink:left; yabai -m window --resize left:20:0
tree < shift - j        :   skl tree shift+j shrink:down; yabai -m window --resize bottom:0:-20
tree < shift - k        :   skl tree shift+k shrink:up; yabai -m window --resize top:0:20
tree < shift - l        :   skl tree shift+l shrink:right; yabai -m window --resize right:-20:0

## balance size of windows
tree < e                :   skl tree e balance; yabai -m space --balance

## pip-style window (top right corner)
tree < p                :   skl tree p pip; yabai -m window --toggle float; yabai -m window --grid 5:5:3:0:2:2

# make floating window fill screen
shift + alt - up     : skl default shift+alt+up grid:full; yabai -m window --grid 1:1:0:0:1:1

# make floating window fill left-half of screen
shift + alt - left   : skl default shift+alt+left grid:left; yabai -m window --grid 1:2:0:0:1:1

# make floating window fill right-half of screen
shift + alt - right  : skl default shift+alt+right grid:right; yabai -m window --grid 1:2:1:0:1:1

# meet mode - Google Meet controls
## d: toggle mic (sends Cmd+D to Chrome/browser)
meet < d : skl meet d mic; osascript -e 'tell application "System Events" to keystroke "d" using command down'

## e: toggle camera (sends Cmd+E)
meet < e : skl meet e cam; osascript -e 'tell application "System Events" to keystroke "e" using command down'

## q: leave call (sends Cmd+Shift+B for "leave")
meet < q : skl meet q leave; osascript -e 'tell application "System Events" to keystroke "b" using {command down, shift down}'

# quick meet shortcuts (no mode required)
## hyper + d: quick mic toggle
cmd + shift + alt + ctrl - d : skl default hyper+d mic; osascript -e 'tell application "System Events" to keystroke "d" using command down'

# quick ghostty - cmd+shift+return to open new ghostty window
cmd + shift - return : skl default cmd+shift+return term; ~/bin/ghostty-create-window

# toggle keybind cheatsheet popup
ctrl - 0x2C : skl default ctrl+/ cheatsheet; sketchybar --set mode popup.drawing=toggle
