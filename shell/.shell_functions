# explain a shell command
explain () {
  if [ "$#" -eq 0 ]; then
    while read  -p "Command: " cmd; do
      curl -Gs "https://www.mankier.com/api/explain/?cols="$(tput cols) --data-urlencode "q=$cmd"
    done
    echo "Bye!"
  elif [ "$#" -eq 1 ]; then
    curl -Gs "https://www.mankier.com/api/explain/?cols="$(tput cols) --data-urlencode "q=$1"
  else
    echo "Usage"
    echo "explain                  interactive mode."
    echo "explain 'cmd -o | ...'   one quoted command to explain it."
  fi
}

# display nfo file
function nfo () {
  if [[ -e "$1" && $# -eq 1 ]]; then
    iconv -f cp437 -t utf8 "$1"
  elif [[ $# -gt 1 ]]; then
    echo "Usage: nfo <filename>"
    echo "Error: nfo can only read one file at a time."
  elif [[ $# -eq 0 ]]; then
    echo "Usage: nfo <filename>"
    echo "Please specify a file."
  else
    echo "Usage: nfo <filename>"
    echo "Error: $1 not found."
  fi
};

# list last command
lc() {
  local start=${1:-1}
  local end=${2:-"$start"}
  fc -ln -$start -$end | sed 's/^[[:space:]]*//'
}

# yank previous command
yc() {
  lc "$@" | pbcopy
}

# jumpt to most frecent directory matching optional string
z() {
  local dir=$(fdb -q "(?i)$@" | head -n 1)
  [ -z "$dir" ] && return 1
  if cd "$dir"; then
    echo "$dir" | sed "s;^$HOME;~;"
  else
    fdb -d "$dir"
  fi
}

# jump to most frecent directory under current matching optional string
zc() {
  z "$PWD" "$@"
}

# open most frecent file matching optional string
oz() {
  local fp="$(fdb -i "$XDG_DATA_HOME"/open.z -q "(?i)$@" | head -n 1)"
  [ -e "$fp" ] && o "$fp"
}

# All encompassing extract function
extract () { # Command to use based on file extension
  if [ -f $1 ] ; then
      case $1 in
          *.tar.bz2)   tar xvjf $1    ;;
          *.tar.gz)    tar xvzf $1    ;;
          *.tar.xz)    tar xvJf $1    ;;
          *.bz2)       bunzip2 $1     ;;
          *.rar)       unrar x $1     ;;
          *.gz)        gunzip $1      ;;
          *.tar)       tar xvf $1     ;;
          *.tbz2)      tar xvjf $1    ;;
          *.tgz)       tar xvzf $1    ;;
          *.zip)       unzip $1       ;;
          *.Z)         uncompress $1  ;;
          *.7z)        7z x $1        ;;
          *.xz)        unxz $1        ;;
          *.exe)       cabextract $1  ;;
          *)           echo "\`$1': unrecognized file compression" ;;
      esac
  else
      echo "\`$1' is not a valid file"
  fi
}

# start transitioning to these functions for cleaner conditional soruces & PATH
source_if_exists() {
    if [ -f "$1" ]; then
        . "$1";:
    fi
}

path_if_exists() {
    if [ -d "$1" ]; then
        export PATH="$1:$PATH"
    fi
}



