# Sync secrets from 1Password to macOS Keychain (run when keys rotate)
load_secrets() {
  echo "Syncing secrets from 1Password to Keychain..."
  for key in ANTHROPIC_API_KEY OPENAI_API_KEY; do
    security delete-generic-password -s "$key" 2>/dev/null
  done
  security add-generic-password -a "$USER" -s "ANTHROPIC_API_KEY" -w "$(op read 'op://Employee/anthropic api/credential')"
  security add-generic-password -a "$USER" -s "OPENAI_API_KEY" -w "$(op read 'op://Employee/openai api/credential')"
  export ANTHROPIC_API_KEY=$(security find-generic-password -s "ANTHROPIC_API_KEY" -w)
  export OPENAI_API_KEY=$(security find-generic-password -s "OPENAI_API_KEY" -w)
  echo "Done. Keys synced to Keychain and loaded."
}

# Load Anthropic API key from Keychain into current shell (on-demand)
load-anthropic-key() {
  export ANTHROPIC_API_KEY=$(security find-generic-password -s "ANTHROPIC_API_KEY" -w 2>/dev/null)
  echo "ANTHROPIC_API_KEY loaded into shell."
}


# cat files with headers (useful for LLM context)
concat() { [ $# -eq 0 ] && set -- *; for f in "$@"; do printf '=== %s ===\n' "$f"; cat "$f"; printf '\n\n'; done; }

# Track CWD per-tty for yabai-organize (survives title overrides from Claude Code etc.)
__track_cwd() {
  local tty_id=$(tty 2>/dev/null | tr '/' '_')
  [ -n "$tty_id" ] && echo "$PWD" > "/tmp/tty_cwd${tty_id}"
}
if [ -n "$ZSH_VERSION" ]; then
  autoload -U add-zsh-hook
  add-zsh-hook chpwd __track_cwd
  add-zsh-hook precmd __track_cwd
fi
# Write initial CWD on shell start
__track_cwd

# Ring bell after long-running commands (>30s) to trigger tmux alert badge
__bell_after_long_cmd() {
  local elapsed=${EPOCHREALTIME:-0}
  if [[ -n "$__cmd_start" ]]; then
    local dur=$(( ${elapsed%.*} - ${__cmd_start%.*} ))
    if [[ $dur -ge 30 ]]; then
      printf '\a'
    fi
  fi
  unset __cmd_start
}
__cmd_timer_start() {
  __cmd_start=${EPOCHREALTIME:-$SECONDS}
}
if [ -n "$ZSH_VERSION" ]; then
  add-zsh-hook preexec __cmd_timer_start
  add-zsh-hook precmd __bell_after_long_cmd
fi

