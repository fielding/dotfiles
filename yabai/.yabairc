#!/usr/bin/env sh

# Auto-reload scripting addition on Dock restart (e.g. after defaults changes)
yabai -m signal --add event=dock_did_restart action="sudo /opt/homebrew/Cellar/yabai/7.1.17/bin/yabai --load-sa"
sudo /opt/homebrew/Cellar/yabai/7.1.17/bin/yabai --load-sa

# global settings
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
yabai -m config window_shadow                on
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        0.90
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 on
yabai -m config mouse_modifier               fn
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize

# general space settings
yabai -m config layout                       bsp

# Reserve space for sketchybar (height=40 + y_offset=4 + margin=6 ≈ 50px)
yabai -m config external_bar                 all:50:0

yabai -m config top_padding                  4
yabai -m config bottom_padding               20
yabai -m config left_padding                 20
yabai -m config right_padding                20
yabai -m config window_gap                   10

# =====================================================
# FLOAT RULES
# =====================================================
# System/utility windows
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Finder$" title="(Copy|Trash|Bin|Info)" manage=off

# GIMP - float toolboxes/dialogs, tile main image windows
yabai -m rule --add app="^GIMP" title="^Toolbox" manage=off
yabai -m rule --add app="^GIMP" title="^Tool Options" manage=off
yabai -m rule --add app="^GIMP" title="^Layers" manage=off
yabai -m rule --add app="^GIMP" title="^Brushes" manage=off
yabai -m rule --add app="^GIMP" title="^Patterns" manage=off
yabai -m rule --add app="^GIMP" title="^Gradients" manage=off
yabai -m rule --add app="^GIMP" title="^FG/BG" manage=off
yabai -m rule --add app="^GIMP" title="^Colors" manage=off
yabai -m rule --add app="^GIMP" title="^Navigation" manage=off
yabai -m rule --add app="^GIMP" title="^Undo History" manage=off
yabai -m rule --add app="^GIMP" title="^Fonts" manage=off
yabai -m rule --add app="^GIMP" title="^Document History" manage=off
yabai -m rule --add app="^GIMP" title="^Pointer" manage=off
yabai -m rule --add app="^GIMP" title="^Export" manage=off
yabai -m rule --add app="^GIMP" title="^Save" manage=off
yabai -m rule --add app="^GIMP" title="^Open" manage=off
yabai -m rule --add app="^GIMP" title="^Preferences" manage=off

# Inkscape (similar X11/GTK app)
yabai -m rule --add app="^Inkscape" title!="^Inkscape$" manage=off

# Blender popups
yabai -m rule --add app="^Blender" title="^Blender Preferences" manage=off
yabai -m rule --add app="^Blender" title="^Blender File" manage=off

# VLC popups
yabai -m rule --add app="^VLC" title!="^VLC" manage=off

# LibreOffice dialogs
yabai -m rule --add app="^LibreOffice" title="(Options|Preferences|About|Export|Save|Open)" manage=off

# Generic dialog/popup patterns (catches most cross-platform apps)
yabai -m rule --add title="^Preferences$" manage=off
yabai -m rule --add title="^Settings$" manage=off
yabai -m rule --add title="^About " manage=off
yabai -m rule --add title="^Open$" manage=off
yabai -m rule --add title="^Save" manage=off
yabai -m rule --add title="^Export" manage=off
yabai -m rule --add title="^Import" manage=off
yabai -m rule --add title="^Print" manage=off

# =====================================================
# APP ROUTING — disabled, using on-demand organizer instead
# =====================================================

# =====================================================
# SPACE LABELS (must come before display assignment)
# =====================================================
yabai -m space 1 --label main
yabai -m space 2 --label p1
yabai -m space 3 --label p2
yabai -m space 4 --label p3
yabai -m space 5 --label p4
yabai -m space 6 --label notes
yabai -m space 7 --label scratch
yabai -m space 8 --label inbox
yabai -m space 9 --label media
yabai -m space 10 --label comms

# =====================================================
# SPACE-DISPLAY ASSIGNMENT
# =====================================================
# Spaces 1-8 on external display (display 1)
# Spaces 9-10 on laptop display (display 2)
yabai -m space 9 --display 2 2>/dev/null
yabai -m space 10 --display 2 2>/dev/null

# =====================================================
# PER-SPACE LAYOUT OVERRIDES
# =====================================================
yabai -m config --space 10 layout stack   # comms: stack Slack/Gather/Signal

# =====================================================
# INBOX SIGNAL — disabled for now, too aggressive
# =====================================================
# yabai -m signal --add event=window_created action='
#   win=$(yabai -m query --windows --window $YABAI_WINDOW_ID 2>/dev/null)
#   [ -z "$win" ] && exit 0
#   managed=$(echo "$win" | jq -r ".\"is-floating\" | not")
#   [ "$managed" = "false" ] && exit 0
#   win_space=$(echo "$win" | jq -r ".space")
#   focused_space=$(yabai -m query --spaces --space | jq -r ".index")
#   [ "$win_space" = "$focused_space" ] && exit 0
#   app=$(echo "$win" | jq -r ".app")
#   case "$app" in
#     Slack|Gather|Signal|AyuGram|Obsidian|Notion) exit 0 ;;
#   esac
#   yabai -m window $YABAI_WINDOW_ID --space inbox 2>/dev/null
# '

echo "yabai configuration loaded.."
